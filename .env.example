# ─── Factuplan MCP Server ──────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# API Key del panel de desarrollador de Factuplan.
# Se envía en el header x-api-key de cada petición.
FACTUPLAN_API_KEY=

# (Opcional) URL base de la API.
# FACTUPLAN_BASE_URL=https://api.factuplan.com.ec/v1

# (Opcional) Timeout HTTP en segundos.
# FACTUPLAN_HTTP_TIMEOUT=30

# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse
MCP_PORT=8000
